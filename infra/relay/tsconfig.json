{
	"extends": "@repo/typescript-config/base.json",
	"include": ["src/**/*.ts", "test/**/*.ts"],
	"compilerOptions": {
		"lib": ["ES2022", "DOM"],
		"module": "Preserve",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"types": ["node"],
		"noEmit": true,
		"allowImportingTsExtensions": true
	}
}
