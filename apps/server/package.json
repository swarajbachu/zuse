{
	"name": "@zuse/server",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"require": "./src/index.ts"
		},
		"./runtime": {
			"types": "./src/runtime.ts",
			"import": "./src/runtime.ts",
			"require": "./src/runtime.ts"
		}
	},
	"scripts": {
		"serve": "tsx src/bin.ts",
		"check-types": "tsc --noEmit",
		"test": "vitest run test/unit test/integration",
		"test:unit": "vitest run test/unit",
		"test:integration": "vitest run test/integration",
		"test:live-agents": "vitest run ./test/live/agent-smoke.live.ts"
	},
	"dependencies": {
		"@adtention/sdk": "^0.4.0",
		"@anthropic-ai/claude-agent-sdk": "^0.2.126",
		"@modelcontextprotocol/sdk": "^1.0.0",
		"@zuse/agents": "*",
		"@zuse/domain": "*",
		"@zuse/git": "*",
		"@effect/platform-node": "catalog:",
		"@zuse/index": "*",
		"@zuse/pokemon-data": "*",
		"@zuse/sqlite": "*",
		"@zuse/contracts": "*",
		"@zuse/utils": "*",
		"effect": "catalog:",
		"fuzzysort": "catalog:",
		"jose": "^6.2.3",
		"keytar": "^7.9.0",
		"node-pty": "^1.1.0",
		"smol-toml": "^1.3.1",
		"tokenmaxer": "*",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:",
		"@repo/typescript-config": "*",
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"tsx": "4.23.0",
		"vitest": "catalog:"
	}
}
