{
	"extends": ["@repo/typescript-config/base.json", "expo/tsconfig.base"],
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"baseUrl": ".",
		"declaration": false,
		"declarationMap": false,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"paths": {
			"~/*": ["src/*"]
		}
	},
	"include": ["app", "src", "test", "*.js"]
}
