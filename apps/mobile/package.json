{
	"name": "mobile",
	"version": "0.0.0",
	"private": true,
	"main": "expo-router/entry",
	"scripts": {
		"start": "expo start",
		"ios": "expo run:ios",
		"lint": "eslint .",
		"check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
		"test": "vitest run test",
		"test:unit": "vitest run test/unit",
		"test:integration": "vitest run test/integration --passWithNoTests",
		"android": "expo run:android",
		"gen:file-icons": "node scripts/gen-file-icons.mjs"
	},
	"expo": {
		"install": {
			"exclude": [
				"typescript",
				"@types/react"
			]
		},
		"doctor": {
			"appConfigFieldsNotSyncedCheck": {
				"enabled": false
			}
		}
	},
