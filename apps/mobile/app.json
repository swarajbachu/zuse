{
	"expo": {
		"name": "Zuse",
		"slug": "zuse",
		"scheme": "zuse",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/icon.png",
		"userInterfaceStyle": "automatic",
		"ios": {
			"supportsTablet": false,
			"buildNumber": "1",
			"infoPlist": {
				"NSCameraUsageDescription": "Scan pairing codes for local Zuse environments.",
				"NSLocalNetworkUsageDescription": "Connect to a local Zuse server on your network.",
				"NSAppTransportSecurity": {
					"NSAllowsLocalNetworking": true
				},
				"ITSAppUsesNonExemptEncryption": false
			},
			"bundleIdentifier": "com.zuse.sh",
			"appleTeamId": "HMCST4VV42"
		},
		"plugins": [
			"expo-router",
			"expo-dev-client",
			"expo-secure-store",
			"expo-notifications",
			"expo-font",
			"expo-web-browser",
			"expo-status-bar"
		]
	}
}
